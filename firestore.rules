rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ─────────────────────────────────────────────────────────
    // Helper functions
    // ─────────────────────────────────────────────────────────
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return request.auth.uid == uid;
    }

    function isAdmin() {
      return isSignedIn() && request.auth.token.email == 'contact.manikaditya@gmail.com';
    }

    // Check if the requesting user is the leader of a team doc
    function isTeamLeader(teamData) {
      return isSignedIn() && teamData.leaderId == request.auth.uid;
    }

    // Check if the requesting user is already in the team members array
    function isTeamMember(teamData) {
      return isSignedIn() && request.auth.uid in teamData.members;
    }

    // ─────────────────────────────────────────────────────────
    // USERS collection
    // ─────────────────────────────────────────────────────────
    match /users/{userId} {
      // Any signed-in user can read other user profiles (for search/leaderboard)
      allow read: if isSignedIn();

      allow create: if isOwner(userId) || isAdmin();
      allow delete: if isAdmin();
      allow update: if isAdmin() || (
        isOwner(userId) && (
          // If a username is already set, they cannot change it
          !("username" in resource.data) || 
          resource.data.username == "" || 
          !("username" in request.resource.data) ||
          request.resource.data.username == resource.data.username
        )
      );
    }

    // ─────────────────────────────────────────────────────────
    // TEAMS collection
    // ─────────────────────────────────────────────────────────
    match /teams/{teamId} {
      // Any signed-in user can read team data (needed to fetch team on profile load)
      allow read: if isSignedIn();

      // Any signed-in user can CREATE a new team (they become leader)
      allow create: if isSignedIn()
        && request.resource.data.leaderId == request.auth.uid
        && request.auth.uid in request.resource.data.members;

      // UPDATE rules:
      // - The team leader can do full updates (rename, remove members, etc.)
      // - Any signed-in user can join a team (add themselves to members[])
      //   provided they are only ADDING themselves (not modifying other fields)
      allow update: if isSignedIn() && (
        // Leader can update anything on the team
        isTeamLeader(resource.data)
        ||
        // Any authenticated user can join or leave by modifying ONLY their own presence in the members array
        (
          request.resource.data.leaderId == resource.data.leaderId
          && request.resource.data.name == resource.data.name
          && (
            // Case 1: Joining (adding themselves to members)
            (
              request.resource.data.members.size() == resource.data.members.size() + 1
              && request.resource.data.members.removeAll(resource.data.members)[0] == request.auth.uid
            )
            ||
            // Case 2: Leaving (removing themselves from members)
            (
              request.resource.data.members.size() == resource.data.members.size() - 1
              && resource.data.members.removeAll(request.resource.data.members)[0] == request.auth.uid
            )
          )
        )
        ||
        // Admin can do anything
        isAdmin()
      );

      // Only admin can delete teams
      allow delete: if isAdmin();
    }

    // ─────────────────────────────────────────────────────────
    // MESSAGES collection
    // ─────────────────────────────────────────────────────────
    match /messages/{messageId} {
      // Can read a message if you are a participant or admin
      allow read: if isSignedIn()
        && (request.auth.uid in resource.data.participants 
          || resource.data.senderId == request.auth.uid
          || resource.data.receiverId == request.auth.uid
          || isAdmin());

      // Can create a message only as yourself
      allow create: if isSignedIn()
        && request.resource.data.senderId == request.auth.uid;

      // Messages cannot be updated or deleted by users
      allow update, delete: if isAdmin();
    }

    // ─────────────────────────────────────────────────────────
    // REPO_SUBMISSIONS collection
    // ─────────────────────────────────────────────────────────
    match /repo_submissions/{docId} {
      // Users can read their own submissions; admin reads all
      allow read: if isSignedIn()
        && (resource.data.userId == request.auth.uid || isAdmin());

      // Any signed-in user can submit a repo (create)
      allow create: if isSignedIn()
        && request.resource.data.userId == request.auth.uid;

      // Only admin can update status (approve/reject)
      allow update: if isAdmin();

      allow delete: if isAdmin();
    }

    // ─────────────────────────────────────────────────────────
    // HACKATHON_REGISTRATIONS collection
    // ─────────────────────────────────────────────────────────
    match /hackathon_registrations/{docId} {
      allow read: if isSignedIn()
        && (resource.data.userId == request.auth.uid || isAdmin());

      allow create: if isSignedIn()
        && request.resource.data.userId == request.auth.uid;

      allow update, delete: if isAdmin();
    }

    // ─────────────────────────────────────────────────────────
    // PROJECT_PROPOSALS collection
    // ─────────────────────────────────────────────────────────
    match /project_proposals/{docId} {
      allow read: if isSignedIn()
        && (resource.data.userId == request.auth.uid || isAdmin());

      allow create: if isSignedIn()
        && request.resource.data.userId == request.auth.uid;

      allow update, delete: if isAdmin();
    }

    // ─────────────────────────────────────────────────────────
    // Deny everything else by default
    // ─────────────────────────────────────────────────────────
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
